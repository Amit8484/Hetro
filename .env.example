# Cloudinary Configuration
# Get these values from https://cloudinary.com/console
# 
# REACT_APP_CLOUDINARY_CLOUD_NAME: Your Cloudinary account name
# REACT_APP_CLOUDINARY_UPLOAD_PRESET: Upload preset created in Cloudinary Settings > Upload
# REACT_APP_CLOUDINARY_API_KEY: Your Cloudinary API Key (keep this secret!)

REACT_APP_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
REACT_APP_CLOUDINARY_UPLOAD_PRESET=your_upload_preset_here
REACT_APP_CLOUDINARY_API_KEY=your_api_key_here
